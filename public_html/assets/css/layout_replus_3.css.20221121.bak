	/* [PC] 캠페인 목록 */
	.pc_wrap .cmp_wrap { width:100%; margin:71px auto 0; }
	.pc_wrap .cmp_wrap .cmp_subject { 
		width:100%; height: 24px; margin: 4px 0 6px; 
