/** - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
 | Sticky Footer
 */
	html, body {
	  height: 100%;
	}
	body {
	  display: flex;
	  flex-direction: column; /* 아이템 배치 방향 ↓ */
	}
	.layout_content {
	  flex: 1 0 auto;
	  width: 100%;
	}
	.layout_footer {
	  flex-shrink: 0;
	}

	/* scrollbar style */
	body {
	  overflow-y:scroll;
	  -ms-overflow-style: -ms-autohiding-scrollbar;             /* <=== 익스플로러를 위한 CSS */ 
	  scrollbar-width: thin; scrollbar-color: #2f3542 #C4C4C4;  /* <=== 파이어폭스를 위한 CSS */ 
	}
	body::-webkit-scrollbar {width: 7px;}
	body::-webkit-scrollbar-thumb {background-color: #2f3542;}
	body::-webkit-scrollbar-track {background-color: #C4C4C4;}



/** - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
 | [COMMON] reset
 */

	/* [PC wrap] - - -  - - -  - - -  - - -  - - -  - - -  */
	.pc_wrap {}
	.pc_wrap .main_sect { width: 100%; margin:0 auto; padding:0; max-width: 1280px; }
	.pc_wrap .main_ctnt { width: 100%; margin:0 auto; padding:0 20px; }


	/* [MOBILE wrap] - - -  - - -  - - -  - - -  - - -  - - -  */
	.mobile_wrap {}
	.mobile_wrap .main_ctnt { width: 100%; margin:0 auto; padding:0 20px; }



	/* 공통 */
	/* 공통 */
	.ctnt_wrap { margin:0 auto; width:100%; max-width: 1280px; }
	.ctnt_inside { margin:0 auto; padding:0 20px; width:100%; }

	/* [ETC] - - -  - - -  - - -  - - -  - - -  - - -  */

	hr.only_line { width:100% !important; height:0 !important; background-color:parent; }




/** - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
 | [COMMON] Header 
 */



	.pc_wrap .header_area {position:relative; width:100%; height:auto;  min-height:90px; max-height:145px;}
	.pc_wrap .header_wrap {position:fixed; width:100%; height:145px; z-index:110; margin: 0 auto; padding:0 20px; transition:.5s;}


	.pc_wrap .header_wrap .header_max { width: 100%; max-width: 1280px; margin:0 auto; }
	.pc_wrap .header_wrap .header_max .top_logo {position:absolute; top:0; left:0; z-index:1;}
	.pc_wrap .header_wrap .header_max .top_logo a {display: block; padding: 43px 0 49px 20px; transition:.5s;}
	.pc_wrap .header_wrap .header_max .top_logo img {height: 56px; transition:.5s;}



	/*
	.pc_wrap .header_wrap .top_logo {position:absolute; top:0; left:0; z-index:1;}
	.pc_wrap .header_wrap .top_logo a {display: block; padding: 51px 65px 49px 101px; transition:.5s;}
	.pc_wrap .header_wrap .top_logo img { height: 40px; transition:.5s; }
	*/
	.pc_wrap .header_wrap .top_nav {
		position: absolute; width: 100%; top: 57px; left: 0; text-align: center; 
		transition:.5s;
	}

	.pc_wrap .header_wrap .top_nav .top_nav_center { display: inline-block; margin-left: -60px;}
	.pc_wrap .header_wrap .top_nav a {
		margin: 0 1vw; text-decoration: none; color: #ffffff;  font-size: 20px; font-weight: bold; 
	}
	.pc_wrap .header_wrap .top_nav a.active { color:#58ae31; }

	.pc_wrap .header_wrap .top_util { position: absolute; top: 60px; right: 20px; transition:.5s;}
	.pc_wrap .header_wrap .top_util a { margin: 0 0 0 15px; text-decoration: none; color: #ffffff; font-size: 17px; font-weight: normal; }
	.pc_wrap .header_wrap .top_util a img { width: 18px; height: 18px; vertical-align: bottom; margin-bottom: 4px; }









	/* scrolled */
	.pc_wrap .header_wrap.scrolled { 
		background-color:#ffffff;  border-bottom: 1px solid #a7a6ae; 
		transition:.5s;
		height: 90px;
	}
	.pc_wrap .header_wrap.scrolled .top_nav {top: 30px; }
	.pc_wrap .header_wrap.scrolled .top_nav a { color: #3d3c43; }
	.pc_wrap .header_wrap.scrolled .top_nav a.active { color: #58ae31; }
	.pc_wrap .header_wrap.scrolled .top_util a { color: #3d3c43; }

	.pc_wrap .header_wrap.scrolled .top_logo a { padding: 24px 65px 29px 101px; }
	.pc_wrap .header_wrap.scrolled .top_logo img { height: 40px; }

	.pc_wrap .header_wrap.scrolled .top_util { top: 30px;  }





	.pc_wrap .header_wrap.scrolled .header_max .top_logo {}
	.pc_wrap .header_wrap.scrolled .header_max .top_logo a {padding: 24px 0 29px 20px; }
	.pc_wrap .header_wrap.scrolled .header_max .top_logo img {}






	/* Mobile */

	.mobile_wrap .header_area {position:relative; width:100%; /*height:20vw;*/ height:80px; }
	.mobile_wrap .header_wrap { position:fixed; width:100%; /*height:20vw;*/ height:80px;  z-index:110;}

	.mobile_wrap .header_wrap .top_logo {position:absolute; top:0; left:0;}
	.mobile_wrap .header_wrap .top_logo img {
	  /*width:25vw;*/ width:100px; height: auto; /* margin: 6vw 0 0 7vw; */ margin: 24px 0 0 20px; object-fit: contain;
	}

	/* Mobile nav button */
	/*
	.mobile_wrap .header_wrap .hamberger_btn {position: absolute;top:5.5vw;right:7vw; outline:none; text-decoration:none;}
	.mobile_wrap .header_wrap .hamberger_btn div {width: 6vw; height: 2px; background-color: #ffffff; margin: 2vw 0;outline:none;text-decoration:none; }
	*/
	.mobile_wrap .header_wrap .hamberger_btn {position: absolute;top:18px;right:25px; outline:none; text-decoration:none;}
	.mobile_wrap .header_wrap .hamberger_btn div {width: 26px; height: 2px; background-color: #ffffff; margin: 10px 0;outline:none;text-decoration:none; }



	/* scrolled */
	.mobile_wrap .header_wrap.scrolled { background-color:#ffffff;  border-bottom: 1px solid #a7a6ae;}
	.mobile_wrap .header_wrap.scrolled .hamberger_btn div { background-color: #3d3c43; }


	/* Mobile nav offcanvas */
	#offcanvasRightMobile {width:100%; max-width:360px;}
	#offcanvasRightMobile .offcanvas-header {transition: all .5s ease-in-out;background-color: transparent;padding-top: 1rem;padding-bottom: 1rem;box-shadow: 0px 3px 6px 0px rgba(0, 0, 0, 0.06);background-color:#ffffff; height:56px;}

	#offcanvasRightMobileLabel {width:calc(100% - 45px); margin-bottom:-2px;}

	.hamberger_btn_close {position: absolute;top:13px;right:13px; background-color:#c0c0c0; padding:3px 5px;}
	.hamberger_btn_close div.bar1, .hamberger_btn_close div.bar2, .hamberger_btn_close div.bar3 {
	  width: 22px; height: 2px; background-color: #ffffff; margin: 5px 0;background-color: #ffffff;transition: 0.4s;
	}
	.hamberger_btn_close .bar1 {-webkit-transform: rotate(-45deg) translate(-5px, 5px);transform: rotate(-45deg) translate(-5px, 5px);}
	.hamberger_btn_close .bar2 {opacity: 0;}
	.hamberger_btn_close .bar3 {-webkit-transform: rotate(45deg) translate(-5px, -5px);transform: rotate(45deg) translate(-5px, -5px);}


	/*  모바일 - 헤더 */
	@media screen and (max-width: 991px) {

		dl.mobile_navbar {display:block;}
		dl.mobile_navbar > dt {display:block;line-height:30px;padding: 10px 15px; position: relative; cursor:pointer;font-size:17px; font-weight:normal;} 
		dl.mobile_navbar > dt > a {display:block;line-height:26px;position: relative;text-decoration:none; }
		dl.mobile_navbar > dd {margin:0;padding:0; display:none;line-height:30px;padding: 10px 15px; }
		dl.mobile_navbar > dd > a {display:block;line-height:26px; margin-left:10px;  /* margin: 0px 15px 0px 30px; padding:10px 0; */ position: relative;text-decoration:none; }
		dl.mobile_navbar > dd.depth3 > a {display:block;line-height:26px; margin-left:30px;/*margin: 0px 15px 0px 45px;padding:10px 0;*/ position: relative;text-decoration:none; }
		dl.mobile_navbar > dd.depth4 > a {display:block;line-height:26px; margin-left:45px;/*margin: 0px 15px 0px 60px;padding:10px 0;*/ position: relative;text-decoration:none; }

		dl.mobile_navbar > dd > a > span {position:absolute; left:-10px;}


		/* 모바일 메뉴 - 다크 스타일 */
		.mob_nav_dark {}
		.mob_nav_dark dl.mobile_navbar > dt {background-color:#2b2b2b;border-bottom:1px solid #434343;color:#fff;}
		.mob_nav_dark dl.mobile_navbar > dt > a {background-color: #2b2b2b;border:none;color:#fff;  font-size:16px; font-weight:600; }
		.mob_nav_dark dl.mobile_navbar > dt:hover, 
		.mob_nav_dark dl.mobile_navbar > dt:hover > a,
		.mob_nav_dark dl.mobile_navbar > dt.active, 
		.mob_nav_dark dl.mobile_navbar > dt.active > a { background-color: #000000;}
		.mob_nav_dark dl.mobile_navbar > dd > a {background-color: #4c4c4c;border-bottom:1px solid #818181;color:#dfdfdf;  font-size:14px; font-weight:normal;}
		.mob_nav_dark dl.mobile_navbar > dd:hover > a,
		.mob_nav_dark dl.mobile_navbar > dd.active > a {background-color: #4c4c4c;color:#dfdfdf;}

		.mob_nav_dark dl.mobile_navbar > dd.depth3 > a {background-color: #646464;color:#ccc;}
		.mob_nav_dark dl.mobile_navbar > dd.depth3:hover > a,
		.mob_nav_dark dl.mobile_navbar > dd.depth3.active > a {background-color: #646464;color:#ccc;}

		.mob_nav_dark dl.mobile_navbar > dd.depth4 > a {background-color: #646464;color:#ccc;}
		.mob_nav_dark dl.mobile_navbar > dd.depth4:hover > a,
		.mob_nav_dark dl.mobile_navbar > dd.depth4.active > a {background-color: #646464;color:#ccc;}


		/* 모바일 메뉴 - 그레이 스타일 */
		.mob_nav_gray {}
		.mob_nav_gray dl.mobile_navbar > dt {background-color:#FFFFFF;border-top:1px solid #dddddd;color:#333333;}
		.mob_nav_gray dl.mobile_navbar > dt.m10 { border-top: none;} 
		.mob_nav_gray dl.mobile_navbar > dt > a {background-color: #FFFFFF;border:none;color:#333333;  font-size:16px; font-weight:600;  display:block; width:100%;}

		.mob_nav_gray dl.mobile_navbar > dt:hover, 
		.mob_nav_gray dl.mobile_navbar > dt:hover > a { background-color: #aaaaaa; color:#ffffff;}
		.mob_nav_gray dl.mobile_navbar > dt.active, 
		.mob_nav_gray dl.mobile_navbar > dt.active > a { /* background-color: #585858; color:#ffffff; */}

		/* .mob_nav_gray dl.mobile_navbar > dt.active + dd { display:block;} */

		.mob_nav_gray dl.mobile_navbar > dd {background-color:#f8f8f8;/*background-color: #cccccc;*/ border-top:1px dashed #aaaaaa;}
		.mob_nav_gray dl.mobile_navbar > dd:first-of-type { border-top:0px dashed #aaaaaa;}
		.mob_nav_gray dl.mobile_navbar > dd > a {color:#333333;  font-size:14px; font-weight:normal; position: relative;}
		.mob_nav_gray dl.mobile_navbar > dd:hover > a,
		.mob_nav_gray dl.mobile_navbar > dd.active > a {color:#333333; }

		.mob_nav_gray dl.mobile_navbar > dd.depth3 {/*background-color: #dddddd;*/color:#333333;}
		.mob_nav_gray dl.mobile_navbar > dd.depth3 > a {/*background-color: #dddddd;*/color:#333333;}
		.mob_nav_gray dl.mobile_navbar > dd.depth3:hover > a,
		.mob_nav_gray dl.mobile_navbar > dd.depth3.active > a {color:#333333; }

		.mob_nav_gray dl.mobile_navbar > dd.depth4 {/*background-color: #eeeeee;*/color:#333333;}
		.mob_nav_gray dl.mobile_navbar > dd.depth4 > a {/*background-color: #eeeeee;*/color:#333333;}
		.mob_nav_gray dl.mobile_navbar > dd.depth4:hover > a,
		.mob_nav_gray dl.mobile_navbar > dd.depth4.active > a {color:#333333; }

		.mob_nav_gray dl.mobile_navbar > dt a { /* text-decoration:underline; */ display:inline-block;}
		.mob_nav_gray dl.mobile_navbar > dd a { /* text-decoration:underline; */ display:inline-block;}


		/* .actived */
		/*
		.mob_nav_gray dl.mobile_navbar > dt.actived a::before {
		  transition: 300ms;
		  height: 4px;
		  content: "";
		  position: absolute;
		  background-color: #6565b4;
		  bottom: -5px;
		  opacity: 1;
		  width: 100%;
		}
		.mob_nav_gray dl.mobile_navbar > dt.actived.active a::before {
		  background-color: #6565b4;
		}

		.mob_nav_gray dl.mobile_navbar > dd.actived a::before {
		  transition: 300ms;
		  height: 3px;
		  content: "";
		  position: absolute;
		  background-color: #6565b4;
		  bottom: -3px;
		  opacity: 1;
		  width: 100%;
		}
		*/
		.mob_nav_gray dl.mobile_navbar > dt.actived a span.activenav::before {
		  transition: 300ms;
		  height: 4px;
		  content: "";
		  position: absolute;
		  background-color: #6565b4;
		  bottom: -5px;
		  opacity: 1;
		  width: 100%;
		}
		.mob_nav_gray dl.mobile_navbar > dt.actived.active a span.activenav::before {
		  background-color: #6565b4;
		}

		.mob_nav_gray dl.mobile_navbar > dd.actived a span.activenav::before {
		  transition: 300ms;
		  height: 3px;
		  content: "";
		  position: absolute;
		  background-color: #6565b4;
		  bottom: -3px;
		  opacity: 1;
		  width: 100%;
		}



		/*
		.mob_nav_gray dl.mobile_navbar > dt > a.icon_depth_plus::after {
			content: "\002B" !important;
			position:absolute;
			right:0;
		}
		*/
		.mob_nav_gray dl.mobile_navbar > dt.icon_depth_plus::after {
			content: "\002B" !important;
			position:absolute;
			right:15px;
		}

		/* 
		.mob_nav_gray dl.mobile_navbar > dd > a.icon_depth_plus::before {  */
		.mob_nav_gray dl.mobile_navbar > dd.icon_depth_plus::after {
			content: "\002B" !important;
			position:absolute;
			right:15px;
		}

		/* Show minus icon when active */
		/*
		.mob_nav_gray dl.mobile_navbar > dt::before {
			content: "\2212" !important;
		}
		*/

	}




















/** - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
 | [COMMON] Footer 
 */

	.layout_footer {position:relative; border-top:1px solid #d5d5d5; padding:0; z-index:1;  background-color:#f2f2f2;}


	/* [PC] 푸터 공지사항 */
		.pc_wrap .footer_notice_wrap {
			position:relative; width: 100%; padding:47px 0 45px; background-color:#ffffff;
			font-family:'Nanum Gothic','NanumGothic','나눔고딕','나눔 고딕', 'Noto Sans KR', AppleSDGothicNeo-Regular,'맑은 고딕','Malgun Gothic',dotum,'돋움',sans-serif;
		}
		.pc_wrap .footer_notice_wrap .notice_ttl {
			font-size: 22px; font-weight: 800; font-stretch: normal; font-style: normal; 
			letter-spacing: -1.4px; text-align: left; color: #000;
		}
		.pc_wrap .footer_notice_wrap .notice_ctnt { 
			position:absolute; left: 150px; top:2px;
			font-size: 19px; font-weight: normal; font-stretch: normal; font-style: normal; letter-spacing: -1.2px; text-align: left;
		}
		.pc_wrap .footer_notice_wrap .notice_ctnt a { text-decoration:none; color: #000; }


	/* [MOBILE] 푸터 공지사항 */
		.mobile_wrap .footer_notice_wrap {
			position:relative; width: 100%; padding:30px 0 25px; background-color:#ffffff;
			font-family:'Nanum Gothic','NanumGothic','나눔고딕','나눔 고딕', 'Noto Sans KR', AppleSDGothicNeo-Regular,'맑은 고딕','Malgun Gothic',dotum,'돋움',sans-serif;
		}
		.mobile_wrap .footer_notice_wrap .notice_ttl {
			width:24vw; font-size: 4vw; font-weight: 800; font-stretch: normal; font-style: normal; 
			letter-spacing: -1.4px; text-align: left; color: #000;
		}
		.mobile_wrap .footer_notice_wrap .notice_ctnt { 
			position:absolute; left: 25vw; top:0px; width: 70vw;
			font-size: 4vw; font-weight: normal; font-stretch: normal; font-style: normal; letter-spacing: -1.2px; text-align: left;
		}
		.mobile_wrap .footer_notice_wrap .notice_ctnt a { text-decoration:none; color: #000; }





	/* [PC] 푸터 내용 */
	.pc_wrap .footer_wrap {
		position:relative;margin:0 auto; width:100%; padding:0 20px; border-top:1px solid #d5d5d5;
		font-family:'Nanum Gothic','NanumGothic','나눔고딕','나눔 고딕', 'Noto Sans KR', AppleSDGothicNeo-Regular,'맑은 고딕','Malgun Gothic',dotum,'돋움',sans-serif;
	}
	.pc_wrap .footer_wrap .footer_logo { margin-top: 70px; }
	.pc_wrap .footer_wrap .footer_link { margin-top:65px; font-size: 18px; }
	.pc_wrap .footer_wrap .footer_link ul {list-style: none; padding:0; }
	.pc_wrap .footer_wrap .footer_link ul li {display:inline-block; }
	.pc_wrap .footer_wrap .footer_link ul li a {text-decoration: none; font-size: 18px; text-align: left; color: #3d3c43; }
	.pc_wrap .footer_wrap .footer_link ul li.h_line { display:inline-block; margin:0 15px; width: 1px; height: 14px;  background-color: #3d3c43;}

	.pc_wrap .footer_wrap .footer_info { position: relative; font-size: 14px; color: #828282; }
	.pc_wrap .footer_wrap .footer_info div {
		font-size: 18px; font-weight: normal; font-stretch: normal; font-style: normal; 
		line-height: 170%; letter-spacing: normal; text-align: left; color: #3d3c43; 
	}

	/* [MOBILE] 푸터 내용 */
	.mobile_wrap .footer_wrap {
		position:relative;margin:0 auto; width:100%; padding:10vw 20px 8vw; border-top:1px solid #d5d5d5;
		font-size:3.3vw;
		font-family:'Nanum Gothic','NanumGothic','나눔고딕','나눔 고딕', 'Noto Sans KR', AppleSDGothicNeo-Regular,'맑은 고딕','Malgun Gothic',dotum,'돋움',sans-serif;
	}
	.mobile_wrap .footer_wrap .footer_logo { }
	.mobile_wrap .footer_wrap .footer_logo img { width: 25vw;}
	.mobile_wrap .footer_wrap .footer_link { margin-top:9vw; }
	.mobile_wrap .footer_wrap .footer_link ul {list-style: none; padding:0; }
	.mobile_wrap .footer_wrap .footer_link ul li {display:inline-block; }
	.mobile_wrap .footer_wrap .footer_link ul li a {text-decoration: none; text-align: left; color: #3d3c43; }

	.mobile_wrap .footer_wrap .h_line { display:inline-block; margin:0 2vw; width: 1px; height: 2.2vw;  background-color: #3d3c43;}

	.mobile_wrap .footer_wrap .footer_info { position: relative; color: #828282; }
	.mobile_wrap .footer_wrap .footer_info div {
		font-weight: normal; font-stretch: normal; font-style: normal; 
		line-height: normal; letter-spacing: normal; text-align: left; color: #3d3c43; 
	}







/** - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
 | [MAIN] MOBILE 버전
 */

	/* 모바일 메인 탑 배너*/
		.mobile_wrap .main_top_bnr {
			position:relative; z-index:1; 
			background-repeat:no-repeat; background-position:top center; background-size:cover; background-color: rgba(5, 5, 5, 0.5);
			width:100%; height:85vw; /* padding: 260px 100px 0 101px; */ /* flex-grow: 0; margin: 0 0 67px; padding: 51px 100px 206px 101px; */
			padding-top:30vw;
		}
		.mobile_wrap .main_top_bnr .txt1 {
			margin: 0 auto; /* height: 83px; flex-grow: 0;  */
			font-family:'Nanum Pen Script', serif; font-size: 11vw; font-weight: normal; font-stretch: normal; font-style: normal;
			letter-spacing: normal; text-align: center; color: #fff;
		}
		.mobile_wrap .main_top_bnr .txt2 {
			margin: 0 auto; /* height: 58px; flex-grow: 0;  */
			font-family:'Nanum Pen Script', serif; font-size: 6vw; font-weight: normal; font-stretch: normal; font-style: normal;
			letter-spacing: normal; text-align: center; color: #fff;
		}

	/* 모바일 메인 캠페인 목록 */
		.mobile_wrap .main_cmp { width:100%; margin:7vw auto 0; }
		.mobile_wrap .main_cmp .cmp_subject { 
			width:100%; margin: 4px 0 6px; 
			font-family:'Nanum Gothic','NanumGothic','나눔고딕','나눔 고딕', 'Noto Sans KR', AppleSDGothicNeo-Regular,'맑은 고딕','Malgun Gothic',dotum,'돋움',sans-serif;
			font-size: 4.5vw; font-weight: bold; font-stretch: normal; font-style: normal; 
			line-height: normal; letter-spacing: normal; text-align: left; color: #3d3c43;
		}
		.mobile_wrap .main_cmp .cmp_subject_line { margin-top:10px; border:none; background-color:#000; height:2px !important; opacity:1;}

		.mobile_wrap .main_cmp .cmp_list {}
		.mobile_wrap .main_cmp .cmp_list ul {list-style:none; padding:0;}
		.mobile_wrap .main_cmp .cmp_list ul li { margin:10px 0; }
		.mobile_wrap .main_cmp .cmp_list ul li .cmp_img_wrap {padding:0px; background-color:rgba(217, 217, 217, 0.4); }
		.mobile_wrap .main_cmp .cmp_list ul li .cmp_img_wrap .cmp_img {
			width:100%; height:30vw;
			background-repeat:no-repeat; background-position:center center; background-size:cover;
		}

		.mobile_wrap .main_cmp .cmp_list ul li .cmp_list_item { 
			padding: 5vw 3vw; /* 56px 30px 30px 37px;  */
			font-family:'Nanum Gothic','NanumGothic','나눔고딕','나눔 고딕', 'Noto Sans KR', AppleSDGothicNeo-Regular,'맑은 고딕','Malgun Gothic',dotum,'돋움',sans-serif;
		}
		.mobile_wrap .main_cmp .cmp_list ul li .cmp_list_item .cmp_cate { 
			font-size: 3.2vw; font-weight: normal; font-stretch: normal; font-style: normal; 
