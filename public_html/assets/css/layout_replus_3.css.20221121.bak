/** - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
 | common - auth layer
 */

		.auth_table {margin:0 auto; padding:100px 0; vertical-align: middle; width:90%; max-width:420px; display:table;}
		@media screen and (max-width: 990px) {
			/* 모바일 */
			.auth_table {padding:30px 0;}

		}
		.auth_table_cell {display:table-cell; background-color:#ffffff;}
		.auth_subject {position:relative; margin-bottom:30px;font-size:24px; font-weight:600; margin-bottom:15px;}

		.auth_ttl {font-size:17px; font-weight:600; margin-bottom:5px;}
		.auth_desc {margin-bottom:15px; border: 1px solid #ddd;padding:2px 3px; background-color:#f7f7f7}
		.auth_input {width:100%;border:none;outline:0;background-color:#f7f7f7; font-size:18px;}

		.auth_table .form-floating > input {background-color: #f7f7f7;}

		.msg_table {margin:40px auto; width:96%; max-width:980px; display:table; }
		.msg_table_cell {display:table-cell;}





		.partners_ctnt {}
		.partner_ci {text-align:center; line-height:100px; margin:10px 0;}









	/** 마이페이지 :: 메인페이지 + + + + + + + + + + + + + + + + + + + + + + + + + + + + */

		.mypage_side { display:inline-block; float:left; width: 220px; padding:0; }
			.my_profile_wrap { padding:30px 0;  text-align: center; background-color:#848b91; color:#ffffff; font-size:15px;}
			.my_profile_id {vertical-align: middle; }
			/*
			.my_profile_img {
				border-radius: 50%;
				vertical-align: top;
			}
			*/

			.my_lnb {
				padding: 48px 34px 44px 32px;
				border: 1px solid #dcdcdc;
				border-top: 0;
				background-color: #fafafa;
			}

			.my_lnb a { text-decoration:none; }

			.my_lnb_item {
				display: block;
				position: relative;
				margin-top: 49px;
				font-size: 17px;
			}
			.my_lnb_item:before {
				position: absolute;
				top: -25px;
				right: 0;
				left: 0;
				height: 1px;
				background-color: #e0e0e0;
				content: '';
			}
			.my_lnb_item:first-child {
				margin-top: 0;
			}
			.my_lnb_item:first-child:before {
				top: 0;
				height: 0px;
				background-color: parent;
			}
			.my_lnb_item[aria-current=true] {
				/* font-weight: 700; */
				color: #7676ba;
			}

			.my_lnb_sub_item {
				display: block;
				margin-top: 17px;
				font-size: 15px;
				color: #828282;
			}
			.my_lnb_sub_item+.my_lnb_sub_item {
				margin-top: 8px;
			}

		/*
		.mypage_ctnt { position:relative; float:right; margin-left:40px;  width:880px; display:inline-block; }
		*/




	/** 마이페이지 :: 캠페인 모바일 메뉴 + + + + + + + + + + + + + + + + + + + + + + + + + + + + */

		.m_slide_nav {width:100%; height:60px; overflow:none; border-bottom: 1px solid rgba(0,0,0,.1);}
		.m_slide_nav_wrap {width:100%;overflow:none; }
		.m_slide_nav_wrap::before {
			content: "";
			display: block;
			position: absolute;
			top: 0;
			/* right: 0; */
			left: 0;
			border-bottom: 1px solid rgba(0,0,0,.1);
		}

		.m_list_nav {
			overflow: hidden;
			overflow-x: auto;
			position: relative;
			z-index: 1;
			font-size: 0;
			line-height: 0;
			white-space: nowrap;
		}

		.m_list_nav {
			-ms-overflow-style: none; /* IE and Edge */
			scrollbar-width: none; /* Firefox */
		}
		.m_list_nav::-webkit-scrollbar {
			display: none; /* Chrome, Safari, Opera*/
		}

		.m_list_nav ul {
			margin:6px 0 0 0;

			list-style: none;
			display: -webkit-inline-box;
			display: -webkit-inline-flex;
			display: inline-flex;
			min-width: 100%;
			-webkit-box-pack: justify;
			-webkit-justify-content: space-between;
			justify-content: space-between;
			vertical-align: top;
			padding: 0 10px;
			-webkit-box-sizing: border-box;
			box-sizing: border-box;
			}

		}
		.m_list_nav ul li {
			position: relative;
			display: inline-block;
			vertical-align: top;
			margin: 0 1px 0 0;
			padding: 0 10px;
			color: #333;
			text-align: center;
			cursor: pointer;
		}


		.m_list_nav ul li span {
			padding: 0 5px;
			font-size: 17px;
		}

		.m_list_nav ul li span {
			text-decoration: none;
			display: inline-block;
			position: relative;
		}
		.m_list_nav ul li span {
			cursor: pointer;
			text-align: center;
			white-space: nowrap;
			padding: 0;
			margin: 0;
			color: #888888;
			line-height: 60px;
			display: inline-block;
			text-decoration: none;
		}

		.m_list_nav ul li span a {
			padding: 0;
		}
		.m_list_nav ul li span a {
			text-decoration: none;
			color: #888888;
			display: inline-block;
			padding: 0 20px;
		}
		.m_list_nav ul li span a:nth-child(1) {
			padding-left:0;
		}

		.mypage_ctnt {width:100%;}
		/*
		@media screen and (min-width: 768px) {
			.mypage_ctnt {width:78%; max-width:880px; margin-left:2%;}
		}
		*/





	/** 마이페이지 :: 캠페인 만들기 + + + + + + + + + + + + + + + + + + + + + + + + + + + + */

		#campaign_write_wrap {}

		#campaign_write_wrap .campaign_ctnt { position:relative; width:100%; max-width:1200px; padding:0 15px;}

		form .campaign_ctnt dl, form .campaign_ctnt dl dt, form .campaign_ctnt dl dd {position:relative;}
		form .campaign_ctnt dl dt {font-size:18px; font-weight: 500; }
		form .campaign_ctnt dl dd {margin-top:5px; }
		form .campaign_ctnt dl dd span.money_unit {position:absolute; right: 15px; line-height:40px; font-size:28px; }

		.goal_device {line-height: 40px; }



		#campaign_write_wrap .cmp_ctnt { position:relative; width:750px; display:inline-block; }
		#campaign_write_wrap .cmp_ctnt > figure { margin:0; }
		#campaign_write_wrap .cmp_ctnt > figure > img { max-width:100%; }

		#campaign_write_wrap .cmp_ctnt_side { display:inline-block; float:right; width: 320px; padding:0 10px;}

		#campaign_write_wrap .cmp_side_ttl {font-size:22px;color:#898989;}
		#campaign_write_wrap .cmp_goal_money {position:relative;width:100%; font-size:34px; line-height:40px; padding:0 50px 0 10px; font-weight:bold; }
		#campaign_write_wrap .cmp_goal_unit {position:absolute; top:8px; right:15px; line-height:43px; font-size:34px;}
		#campaign_write_wrap .cmp_goal_desc {width:100%; max-width: 100%; min-width:100%; height:auto; min-height:120px; font-size:24px; color: #434387; line-height:150%; }
		#campaign_write_wrap .cmp_term_begin {font-size:17px; width:100%; }
		#campaign_write_wrap .cmp_term_end {font-size:17px; width:100%;}

		#campaign_write_wrap .cmp_org_wrap {background-color:#efeff8; color:#6c6c6c;}
		#campaign_write_wrap .cmp_org_name {width: 100%; font-size:18px; color: #6c6c6c; }
		#campaign_write_wrap .cmp_org_desc {width:100%; max-width:100%; min-width:100%; color:#6c6c6c; font-size:16px; }

		.campaign_input { line-height:40px; font-size:17px !important; padding:0 10px;}
		.campaign_title { width:100%; font-weight:bold; color:#353535;}
		.campaign_main_img { margin:0; width: 100%; height:auto; min-height: 200px; background-color:#f2f2f2;}
		.campaign_main_img img {width: 100%;}
		.campaign_main_image { /* display:none; */ border:1px solid #fff; margin-top:10px;} 

		.wrap_goal {display:none;}







		.o_request_tbl { position:relative; width:100%; }
		.o_request_row { position:relative; width:100%; padding:20px 0; vertical-align:middle;}

		.o_request_tbl dl { position:relative; clear:both; width:100%; margin:0; padding:0;  vertical-align:middle; }
		.o_request_tbl dl dt div, .o_request_tbl dl dd div { display:inline-block; padding:30px 15px; background-color:#efeff8; line-height: 120%; }

		.o_request_tbl dl dt {display:inline-block; float:left; width:75px; margin:0; padding:1px 0 0 0;  vertical-align:middle; }
		.o_request_tbl dl dd {display:inline-block; float:right; width:calc(100% - 75px); margin:0; padding:0;  vertical-align:middle;  background-color:#ffffff;}
		.o_request_tbl dl dd input.input_request, textarea.textarea_request {width:100%; border:1px solid #e3e3e3;}
		.o_request_tbl dl dd input.input_request { height:47px; line-height:47px; padding:0 24px;}
		.o_request_tbl dl dd textarea.textarea_request { padding:15px 24px;height:300px;}
		.o_request_tbl br.b_line_request { clear:both; border:none; border-bottom: 1px solid #e1e1e1; margin:0; padding:0;}
		.o_request_tbl hr.b_line_request { clear:both; border:none; border-bottom: 1px solid #e1e1e1; margin:0; padding:0;}












/** - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
 | [나눔신청] PC 버전
 */

	/* 기부 절차 */
	.subpage_wrap { 
		margin:70px 0 50px 0; 
		font-family:'Nanum Gothic','NanumGothic','나눔고딕','나눔 고딕', 'Noto Sans KR', AppleSDGothicNeo-Regular,'맑은 고딕','Malgun Gothic',dotum,'돋움',sans-serif;
	}
	.subpage_wrap .subpage_ttl {margin:0;}
	.subpage_wrap .subpage_ttl .subpage_ttl_text {
		margin: 0; font-size: 40px; font-weight: 800; font-stretch: normal; font-style: normal;
		line-height: normal; letter-spacing: -2.8px; text-align: left; color: #000;
	}
	.subpage_wrap .subpage_ttl .subpage_ttl_line {
		margin:10px 0 0 0; width:100%; max-width: 76px; height: 5px !important; background-color: #58ae31;
	}

	.subpage_wrap .subpage_desc {
		margin: 31px 0 0 0; font-size: 18px; font-weight: normal; font-stretch: normal; font-style: normal; 
		line-height: 150%; letter-spacing: normal; text-align: left; color: #000;
	}
	.subpage_wrap .subpage_img { margin: 24px 0 0 0; }
	.subpage_wrap .subpage_img img { width:100%; }

	.subpage_wrap .subpage_dl dl {
		margin: 50px 0 0 0; font-size: 18px; font-weight: normal; font-stretch: normal; font-style: normal; 
		line-height: 150%; letter-spacing: normal; text-align: left; color: #000;
	}
	.subpage_wrap .subpage_dl dt {font-size:20px;font-weight:bold;font-stretch:normal;font-style:normal;line-height:normal;letter-spacing:-0.6px;text-align:left;color:#3d3c43;}
	.subpage_wrap .subpage_dl dd {font-size:20px;font-weight:normal;font-stretch:normal;font-style:normal;line-height:normal;letter-spacing:-0.6px;text-align:left;color:#3d3c43;}


	.mobile_wrap .subpage_wrap .subpage_ttl .subpage_ttl_text { text-align: center; }
	.mobile_wrap .subpage_wrap .subpage_ttl .subpage_ttl_line {
		margin:20px auto; width:100%; max-width: 76px; height: 5px !important; background-color: #58ae31;
	}
	.subpage_wrap .subpage_dl dl {
		margin: 30px 0 0 0;
	}
