  `new_email` varchar(200) DEFAULT NULL,
  `new_email_key` varchar(50) DEFAULT NULL,
  `last_ip` varchar(40) NOT NULL,
  `last_login` datetime NOT NULL DEFAULT '0000-00-00 00:00:00',
  `cnt_login` int(11) NOT NULL DEFAULT 0,
  `created` datetime NOT NULL DEFAULT '0000-00-00 00:00:00',
  `modified` timestamp NOT NULL DEFAULT current_timestamp() ON UPDATE current_ti                                                    mestamp(),
  `deleted` datetime DEFAULT NULL,
  `dupinfo` varchar(255) DEFAULT NULL COMMENT '나이스 본인인증을 거친 후 발급되                                                    는 중복가입 방지용 고유 확인정보 ',
  `route` varchar(50) DEFAULT NULL COMMENT 'excel (엑셀업로드회원)',
  `memo` varchar(255) DEFAULT NULL,
  `sns` varchar(50) DEFAULT NULL COMMENT 'sns 회원인 경우, sns 회사명(google, na                                                    ver, kakao, ..)',
  PRIMARY KEY (`id`),
  UNIQUE KEY `username` (`username`)
