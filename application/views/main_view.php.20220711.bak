	<script type="text/javascript">
		$(document).ready(function(){

			$('.slick_main_visual').slick({
				  infinite: true,
				  speed: 500,
				  slidesToShow: 1,
				  centerMode: true,
				  variableWidth: true,
				  dots: false,
				  autoplay: true,
				  autoplaySpeed: 4000,
			});


			$('.m_slick_main_visual').slick({
				  infinite: true,
				  speed: 500,
				  slidesToShow: 1,
				  centerMode: true,
				  variableWidth: true,
				  dots: true,
				  autoplay: true,
				  autoplaySpeed: 4000,
			});

			$('.click_opensbox').css('border','0');

			$('.click_opensbox').click(function(){
				var boxno = $(this).attr('id');
				var boxid_open = 'selector'+boxno+'_open';
				var boxid_closed = 'selector'+boxno+'_closed';
				$('.sboxopen').hide();
				$('.sboxclosed').show();
				$('#'+boxid_open).show();
				$('#'+boxid_closed).hide();
			});
			/*

			$('.slick_partner').slick({
				  infinite: true,
				  speed: 500,
				  slidesToShow: 8,
				  centerMode: true,
				  autoplay: true,
				  autoplaySpeed: 1000,
			});

			*/

		});
	</script>