				return false;
			}
			else {
				$('#error_donor_name_org').hide();
			}


			if('A' == donor_type_val && '' == name) {
				$('#error_donor_name').show();
				alert('이름을 입력해주세요.');
				return false;
			}
			else if('B' == donor_type_val && '' == name) {
				$('#error_donor_name').show();
				alert('담당자명을 입력해주세요.');
