<script type='text/javascript'>
//<![CDATA[
	$(function() {

		// 작업요청 전송(기부하기) 상태에서 수거 신청 상태로 업데이트
		$('.btn_updateWaState').on('click',function(){

			const idx = $(this).data('idx');

			var request = $.ajax({
			  url: "/trans/ros_replus_updateWaState/",
			  method: "POST",
			  data: { 'idx': idx, 'reqState' : 1  /* , '<?php echo $this->security->get_csrf_token_name() ?>':'<?php echo $this->security->get_csrf_hash() ?>' */},
			  dataType: "text"
			});

			request.done(function( res ) {

				//console.log(res);
					
				if('SUCCESS' == res) {
					// 상태 변경 성공
					location.reload();
				}
				else {
					// 상태 변경 실패
					alert('수거 신청이 되지 않았습니다. \n계속해서 신청이 되지 않을 경우, 관리자에 문의해주시기 바랍니다.');
				}
			});

			request.fail(function( jqXHR, textStatus ) {
			  alert( "Request failed: " + textStatus );
			});

		});


	});
//]]>
</script>
