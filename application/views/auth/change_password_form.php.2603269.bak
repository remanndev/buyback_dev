<?php
$old_password = array(
	'name'	=> 'old_password',
	'id'	=> 'old_password',
	'class'	=> 'form-control required_field '.( ''!=form_error('old_password') ? 'err_color_red' : '' ),
	'value' => set_value('old_password'),
	'size' 	=> 30,
	'placeholder' => ' ',
	'required' => 'required',
	'autocomplete' => 'off'
);
$new_password = array(
	'name'	=> 'new_password',
	'id'	=> 'new_password',
	'class'	=> 'form-control required_field '.( ''!=form_error('new_password') ? 'err_color_red' : '' ),
	'maxlength'	=> $this->config->item('password_max_length', 'tank_auth'),
	'size'	=> 30,
	'placeholder' => ' ',
	'required' => 'required',
	'autocomplete' => 'off'
);
$confirm_new_password = array(
	'name'	=> 'confirm_new_password',
	'id'	=> 'confirm_new_password',
	'class'	=> 'form-control required_field '.( ''!=form_error('confirm_new_password') ? 'err_color_red' : '' ),
	'maxlength'	=> $this->config->item('password_max_length', 'tank_auth'),
	'size' 	=> 30,
	'placeholder' => ' ',
	'required' => 'required',
	'autocomplete' => 'off'
);

// 모바일에서는 해당 요소 삭제
if(IS_MOBILE) {
	unset($old_password['required']);
	unset($new_password['required']);
	unset($confirm_new_password['required']);
}
?>

<style type="text/css">
/*  .layout_content {background-color: #eeeeee;} */
</style>


<div class="auth_table">
	<div class="auth_table_cell">
		<div class="contents_wrap">

			<h2 class="auth_subject">비밀번호 변경</h2>

			<?php echo form_open($this->uri->uri_string()); ?>
			  <fieldset>
				<legend class="screen_out">비밀번호 변경 입력폼</legend>

				<div class="form-floating mb-3">
				  <?php echo form_password($old_password); ?>
				  <?php echo form_label('기존 비밀번호', $old_password['id']); ?>
				  <div class="err_color_red"><?php echo form_error($old_password['name']); ?><?php echo isset($errors[$old_password['name']])?$errors[$old_password['name']]:''; ?></div>
				</div>

				<div class="form-floating mb-3">
				  <?php echo form_password($new_password); ?>
				  <?php echo form_label('새 비밀번호', $new_password['id']); ?>
				  <div class="err_color_red"><?php echo form_error($new_password['name']); ?><?php echo isset($errors[$new_password['name']])?$errors[$new_password['name']]:''; ?></div>
				</div>

				<div class="form-floating mb-3">
				  <?php echo form_password($confirm_new_password); ?>
				  <?php echo form_label('새 비밀번호 확인', $confirm_new_password['id']); ?>
				  <div class="err_color_red"><?php echo form_error($confirm_new_password['name']); ?><?php echo isset($errors[$confirm_new_password['name']])?$errors[$confirm_new_password['name']]:''; ?></div>
				</div>

				<div class="d-grid gap-2">
				  <?php echo form_submit('change', '비밀번호 변경하기', ' class="btn btn-dark btn-lg" style="font-size:14px; padding:15px; border-radius:0px;"'); ?>
				</div>

				<div style="margin-top:15px;">
					<div>
						<span class="glyphicon glyphicon glyphicon-arrow-left" aria-hidden="true"></span> 
						<?php echo anchor('/auth/login/', '로그인 페이지로 이동', 'style="color:#000;font-size:14px;"'); ?>
					</div>
				</div>

			  </fieldset>
			<?php echo form_close(); ?>

		</div>
	</div>
</div>

