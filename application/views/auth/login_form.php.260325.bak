						</div>
					</div>
				  </fieldset>
				<?php echo form_close(); ?>
			</div>

		</div>
	</div>
</div>

<script type="text/javascript">
$(document).ready(function(){
	$('#btn_email_login').on('click',function(){
		$(this).hide();
		$('#auth_login_wrap').fadeIn();
	});
});
</script>