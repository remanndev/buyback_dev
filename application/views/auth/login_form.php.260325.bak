			// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 
			// 카카오 로그인
			$(document).ready(function() {
				$('#kakaoLoginBtnStart').css('cursor', 'pointer');
				$('#kakaoLoginBtnStart').on('click', function() {
					var rpath_encode = $(this).data('rpath');
					kakaoLogin(rpath_encode);
				});
			});
			function kakaoLogin(rpath_encode) {
				// 페이지 변경 방식
				location.href = '/sns/kakaoAuth/'+rpath_encode;
			}
			</script>
			<div class="mt-4 text-sm-center" style="<?php echo $hide_by_admin ?>">
				<!-- 카카오 계정으로 로그인 .kakaoLoginBtn -->
				<img src="<?php echo IMG_DIR ?>/common/kakao_login_large_wide.png" alt="카카오 로그인" id="kakaoLoginBtnStart" class="" style="width: 100%; " data-rpath="<?php echo $rpath_encode ?>" />
