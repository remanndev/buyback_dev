<?php
// 관리자 페이지(/admin)로의 접속인지를 체크
	$hide_by_admin = '';
	$show_by_admin = '';
	if('admin' == $rpath_admin) {
		$hide_by_admin = 'display: none;';
		$show_by_admin = 'display: block;';
	}


if ($login_by_username AND $login_by_email) {
	//$login_label = 'Email or ID';
	$login_label = '아이디 또는 이메일';
} else if ($login_by_username) {
	$login_label = '아이디';
} else {
	$login_label = '이메일';
}
$login = array(
	'name'	=> 'login',
	'id'	=> 'login',
	'class'	=> 'form-control required_field '.( ''!=form_error('login') ? 'err_color_red' : '' ),
	'value' => set_value('login'),
	'maxlength'	=> 80,
	'size'	=> 30,
	'placeholder' => form_error('login') ? strip_tags(form_error('login')) : $login_label,
	'required' => 'required',
	'autocomplete' => 'off',
	'tabindex' => 1,
);
$password = array(
	'name'	=> 'password',
	'id'	=> 'password',
	'class'	=> 'form-control required_field '.( ''!=form_error('password') ? 'err_color_red' : '' ),
	'size'	=> 30,
	'placeholder' => form_error('password') ? strip_tags(form_error('password')) : '비밀번호',
	'required' => 'required',
	'autocomplete' => 'off',
	'tabindex' => 2,
);
$remember = array(
	'name'	=> 'remember',
	'id'	=> 'remember',
	'value'	=> 1,
	'checked'	=> set_value('remember'),
	'style' => 'margin:0;padding:0',
);

$captcha = array(
	'name'	=> 'captcha',
	'id'	=> 'captcha',
	'maxlength'	=> 8,
	'class'	=> 'form-control required_field '.( ''!=form_error('captcha') ? 'err_color_red' : '' ),
	'placeholder' => form_error('captcha') ? strip_tags(form_error('captcha')) : '인증코드',
	'required' => 'required',
	'autocomplete' => 'off',
	'tabindex' => 3,
);

// 모바일에서는 해당 요소 삭제
if(IS_MOBILE) {
	unset($login['required']);
	unset($password['required']);
	unset($captcha['required']);
}
?>

