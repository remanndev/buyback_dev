<?php
if ($this->config->item('use_username', 'tank_auth')) {
	$login_label = '아이디 또는 이메일';
} else {
	$login_label = '이메일';
}
$login = array(
	'name'	=> 'login',
	'id'	=> 'login',
	'class'	=> 'form-control required_field '.( ''!=form_error('login') ? 'err_color_red' : '' ),
	'value' => set_value('login'),
	'maxlength'	=> 80,
	'size'	=> 30,
	'placeholder' => form_error('login') ? strip_tags(form_error('login')) : $login_label,
	'required' => 'required',
	'autocomplete' => 'off'
);
// 모바일에서는 해당 요소 삭제
if(IS_MOBILE) {
	unset($login['required']);
}
?>

<style type="text/css">
/*  .layout_content {background-color: #eeeeee;} */
</style>


<div class="auth_table">
	<div class="auth_table_cell">
		<div class="contents_wrap">

			<h2 class="auth_subject">비밀번호 재설정</h2>

			<?php echo form_open($this->uri->uri_string()); ?>
			  <fieldset>
				<legend class="screen_out">비밀번호 재설정 입력폼</legend>

				<div class="form-floating mb-3">
				  <?php echo form_input($login); ?>
				  <?php echo form_label($login_label, $login['id']); ?>
				  <div class="err_color_red"><?php echo form_error($login['name']); ?><?php echo isset($errors[$login['name']])?$errors[$login['name']]:''; ?></div>
				</div>

				<div class="d-grid gap-2">
				  <?php echo form_submit('reset', '비밀번호 재설정 메일 받기', ' class="btn btn-dark btn-lg" style="font-size:14px; padding:15px; border-radius:0px;"'); ?>
				</div>

				<div style="margin-top:15px;">
					<div>
						<span class="glyphicon glyphicon-arrow-left" aria-hidden="true"></span> 
						<?php echo anchor('/auth/login/', '로그인 페이지로 이동', 'style="color:#000;font-size:14px;"'); ?>
					</div>
				</div>

			  </fieldset>
			<?php echo form_close(); ?>

		</div>
	</div>
</div>
