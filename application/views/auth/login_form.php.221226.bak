<?php
if ($login_by_username AND $login_by_email) {
	//$login_label = 'Email or ID';
	$login_label = '아이디 또는 이메일';
} else if ($login_by_username) {
	$login_label = '아이디';
} else {
	$login_label = '이메일';
}
$login = array(
	'name'	=> 'login',
	'id'	=> 'login',
	'class'	=> 'form-control required_field '.( ''!=form_error('login') ? 'err_color_red' : '' ),
	'value' => set_value('login'),
	'maxlength'	=> 80,
	'size'	=> 30,
	'placeholder' => form_error('login') ? strip_tags(form_error('login')) : $login_label,
	'required' => 'required',
	'autocomplete' => 'off',
	'tabindex' => 1,
);
$password = array(
	'name'	=> 'password',
	'id'	=> 'password',
	'class'	=> 'form-control required_field '.( ''!=form_error('password') ? 'err_color_red' : '' ),
	'size'	=> 30,
	'placeholder' => form_error('password') ? strip_tags(form_error('password')) : '비밀번호',
	'required' => 'required',
	'autocomplete' => 'off',
	'tabindex' => 2,
);
$remember = array(
	'name'	=> 'remember',
	'id'	=> 'remember',
	'value'	=> 1,
	'checked'	=> set_value('remember'),
	'style' => 'margin:0;padding:0',
);

$captcha = array(
	'name'	=> 'captcha',
	'id'	=> 'captcha',
	'maxlength'	=> 8,
	'class'	=> 'form-control required_field '.( ''!=form_error('captcha') ? 'err_color_red' : '' ),
	'placeholder' => form_error('captcha') ? strip_tags(form_error('captcha')) : '인증코드',
	'required' => 'required',
	'autocomplete' => 'off'
);

// 모바일에서는 해당 요소 삭제
if(IS_MOBILE) {
	unset($login['required']);
	unset($password['required']);
	unset($captcha['required']);
}
?>

<style type="text/css">
/*  .layout_content {background-color: #eeeeee;} */
</style>


<div class="auth_table">
	<div class="auth_table_cell">
		<div class="contents_wrap">

			<h2 class="auth_subject">이메일 로그인</h2>

			<?php echo form_open($this->uri->uri_string()); ?>
			  <fieldset>
				<legend class="screen_out">로그인 입력폼</legend>

				<div class="form-floating mb-3">
				  <?php echo form_input($login); ?>
				  <?php echo form_label($login_label, $login['id']); ?>
				  <div class="err_color_red"><?php //echo form_error($login['name']); ?><?php echo isset($errors[$login['name']])?$errors[$login['name']]:''; ?></div>
				</div>

				<div class="form-floating mb-3">
				  <?php echo form_password($password); ?>
				  <?php echo form_label('비밀번호', $password['id']); ?>
				  <div class="err_color_red"><?php echo form_error($password['name']); ?><?php echo isset($errors[$password['name']])?$errors[$password['name']]:''; ?></div>
				</div>

				<?php if ($show_captcha) {
					if ($use_recaptcha) { ?>
				<div class="mb-3">
					<table>
					<tr>
						<td colspan="2">
							<div id="recaptcha_image"></div>
						</td>
						<td>
							<a href="javascript:Recaptcha.reload()">Get another CAPTCHA</a>
							<div class="recaptcha_only_if_image"><a href="javascript:Recaptcha.switch_type('audio')">Get an audio CAPTCHA</a></div>
							<div class="recaptcha_only_if_audio"><a href="javascript:Recaptcha.switch_type('image')">Get an image CAPTCHA</a></div>
						</td>
					</tr>
					<tr>
						<td>
							<div class="recaptcha_only_if_image">Enter the words above</div>
							<div class="recaptcha_only_if_audio">Enter the numbers you hear</div>
						</td>
						<td><input type="text" id="recaptcha_response_field" name="recaptcha_response_field" /></td>
						<td style="color: red;"><?php echo form_error('recaptcha_response_field'); ?></td>
						<?php echo $recaptcha_html; ?>
					</tr>
					</table>
				</div>
				<?php } else { ?>
				<div class="mb-3">
					<div class="form-floating">
					  <?php echo form_input($captcha); ?>
					  <?php echo form_label('인증코드', $captcha['id']); ?>
					</div>
					<div id="btn_renew_code" class="mt-1" title="클릭하시면 새로운 코드로 갱신됩니다.">
						<span id="span_captcha_html" class="gray_scale"><?php echo $captcha_html; ?></span>
					</div>
					<div class="err_color_red"><?php echo form_error($captcha['name']); ?><?php echo isset($errors[$captcha['name']])?$errors[$captcha['name']]:''; ?></div>
				</div>
				<?php }
				} ?>

				<div class="d-grid gap-2">
				  <?php echo form_submit('submit', '로그인', ' class="btn btn-dark btn-lg" style="font-size:14px; padding:15px; border-radius:0px;"'); ?>
				</div>

				<div style="margin-top:15px; font-size:13px;">
					<div style="float:left;">
						<?php echo form_checkbox($remember); ?>
						<?php echo form_label('로그인 상태 유지', $remember['id']); ?>
					</div>
					<div style="float:right;">
						<?php echo anchor('/auth/forgot_password/', '비밀번호 찾기'); ?>
						 / <?php if ($this->config->item('allow_registration', 'tank_auth')) echo anchor('/auth/register/', '회원가입'); ?>
					</div>
				</div>

			  </fieldset>
			<?php echo form_close(); ?>

			<hr />

			<script src="<?php echo JS_DIR ?>/sns_login.js"></script>
			<div class="row mt-4 text-sm-center">	
				<div class="col-6 border-counters-right">
					<!-- 네이버 계정으로 로그인 -->
					<a href="#"><img src="<?php echo IMG_DIR ?>/common/sns_login_naver.png" alt="네이버 로그인" class="naverLoginBtn"></a> 
				</div>
				<div class="col-6 border-counters-right">
					<!-- 카카오 계정으로 로그인 -->
					<a href="#"><img src="<?php echo IMG_DIR ?>/common/sns_login_kakao.png" alt="카카오 로그인" class="kakaoLoginBtn"></a>
				</div>
			</div>

		</div>
	</div>
</div>
