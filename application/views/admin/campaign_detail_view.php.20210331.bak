<?php } elseif('submit' == $row->state) { ?>
	<a href="#" onclick="launch_confirm('/admin/campaign/launch/<?php echo $row->idx ?>'); return false;"><button type="button" class="btn  btn-success-flat" style="margin:0 auto; width: 100px;">런칭하기</button></a>
<?php } elseif('launch' == $row->state) { ?>
	<button type="button" class="btn  btn-primary-flat" style="margin:0 auto; ">런칭(공개)된 캠페인</button>
<?php } ?>

<script type="text/javascript">

		// 런칭하기
		function launch_confirm(url) {
			if( confirm( '정말 공개하시겠습니까? \n\n공개하신 캠페인은 즉시 캠페인 페이지에 반영됩니다.') ) {
				location.href = url;
			}

		}
</script>